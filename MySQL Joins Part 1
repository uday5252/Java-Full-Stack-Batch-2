-- ===========================
-- Create Ticket_Details Table
-- ===========================
CREATE TABLE Ticket_Details (
    Ticket_No INT PRIMARY KEY,
    Train_Name VARCHAR(50),
    Coach VARCHAR(10),
    Seat_No INT,
    Class VARCHAR(20),
    Fare DECIMAL(10,2)
);

