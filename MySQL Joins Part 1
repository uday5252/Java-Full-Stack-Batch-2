-- Create Database
CREATE DATABASE RailwayDB;

-- Use Database
USE RailwayDB;

-- ===========================
-- Create Passenger Table
-- ===========================
CREATE TABLE Passengers (
    Ticket_No INT PRIMARY KEY,
    Passenger_Name VARCHAR(50),
    Age INT,
    Gender VARCHAR(10),
    Source VARCHAR(50),
    Destination VARCHAR(50)
);

