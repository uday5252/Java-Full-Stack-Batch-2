-- 1) Display the Name of the passenger, his/her train name,
-- coach no, seat no who have booked the ticket

-- Passenger Train     Coach Seat
-- Rahul			Rajdhani  B2     25
-- Priya			Duronto   A1     12
-- Arjun     Shadabdi  C3     18

select 
p.Passenger_name,
td.Train_name,
td.Coach,
td.Seat_No
from passengers as p inner join ticket_Details as td
on p.Ticket_No = td.Ticket_No;

-- 1) Display the Name of the passenger, his/her train name,
-- coach no, seat no who have booked the ticket and also 
-- passengeres who have not booked the ticket 


select 
p.Passenger_name,
td.Train_name,
td.Coach,
td.Seat_No
from passengers as p left join ticket_Details as td
on p.Ticket_No = td.Ticket_No;




-- 1) Display the Name of the passenger, his/her train name,
-- coach no, seat no who have booked the ticket and also 
-- the details of the train where no passenger is travelling
 

select 
p.Passenger_name,
td.Train_name,
td.Coach,
td.Seat_No
from passengers as p right join ticket_Details as td
on p.Ticket_No = td.Ticket_No;


-- write a query to display all 
-- the passengers who are travelling
-- who are not traveling and the trains 
-- which are not booked by
-- any customer   

select 
p.Passenger_name,
td.Train_name,
td.Coach,
td.Seat_No
from passengers as p left join ticket_Details as td
on p.Ticket_No = td.Ticket_No
union
select 
p.Passenger_name,
td.Train_name,
td.Coach,
td.Seat_No
from passengers as p right join ticket_Details as td
on p.Ticket_No = td.Ticket_No;


